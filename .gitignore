# Track source and project inputs, not generated build output.
/*
!/.gitignore
!/README.md
!/rtl/
!/verification/
!/Gowin/

# Gowin IDE generated output and local user state
/Gowin/impl/
/Gowin/*.gprj.user

# Python virtualenvs and caches
**/.venv/
**/__pycache__/
*.pyc
*.pyo

# Simulation build artifacts and waveforms
/verification/build/
/verification/logs/
**/*.vvp
**/*.vcd
**/*.fst
**/*.ghw

# Per-run coverage/result artifacts
/verification/reports/*.jsonl
/verification/reports/*_results.xml

# OS/editor local files
.DS_Store
/.vscode/
